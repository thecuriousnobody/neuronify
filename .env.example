# ───────────────────────────────────────────────────────────────
# Neuronify environment — copy to .env.local and fill in.
# .env.local is gitignored. NEVER commit real secrets.
# ───────────────────────────────────────────────────────────────

# ── Database (Neon Postgres) ──
# Neon dashboard → your project → Connection string (pooled).
# Either name works; POSTGRES_CONNECTION_STRING matches the other projects.
POSTGRES_CONNECTION_STRING="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ── AI provider ──
# Default is Groq (free tier, OpenAI-compatible). Options:
#   groq        → Llama models, free. Needs GROQ_API_KEY.
#   anthropic   → Claude. Needs ANTHROPIC_API_KEY.
#   ollama      → fully local & free. Run `ollama serve`; no key needed.
#   openai      → OpenAI or any OpenAI-compatible host. Needs LLM_API_KEY.
AI_PROVIDER="groq"

# Groq (get a free key at https://console.groq.com/keys)
GROQ_API_KEY=""

# Anthropic (only if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=""

# Generic OpenAI-compatible override (only if AI_PROVIDER=openai/ollama)
# LLM_BASE_URL="http://localhost:11434/v1"
# LLM_API_KEY=""

# ── Web search (optional, brief-time enrichment) ──
# SERPER (https://serper.dev) grounds cost figures and powers the proactive
# "action planner" in the brief. Omit to fall back to the built-in cost table.
SERPER_API_KEY=""

# ── Model overrides (optional) ──
# Defaults: groq → llama-3.1-8b-instant (triage) / llama-3.3-70b-versatile (brief)
#           anthropic → claude-haiku-4-5-20251001 / claude-sonnet-4-6
# AGENT_A_MODEL=""
# AGENT_B_MODEL=""
